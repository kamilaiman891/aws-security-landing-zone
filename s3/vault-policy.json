{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowCloudTrailWrite",
      "Effect": "Allow",
      "Principal": {
        "Service": "cloudtrail.amazonaws.com"
      },
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::central-audit-logging-vault/*"
    },
    {
      "Sid": "DenyAppEngineerDelete",
      "Effect": "Deny",
      "Principal": {
        "AWS": "arn:aws:iam::000000000000:role/ApplicationEngineerRole"
      },
      "Action": [
        "s3:DeleteObject",
        "s3:DeleteBucket"
      ],
      "Resource": [
        "arn:aws:s3:::central-audit-logging-vault",
        "arn:aws:s3:::central-audit-logging-vault/*"
      ]
    }
  ]
}
